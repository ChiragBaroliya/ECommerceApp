@model EcommerceApp.Backend.Models.User
@{
    ViewData["Title"] = "Login";
}
<div class="container mt-5">
    <h2>Login</h2>
    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label asp-for="Username" class="form-label"></label>
            <input asp-for="Username" class="form-control form-control-sm" />
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" type="password" class="form-control form-control-sm" />
        </div>
        <button type="submit" class="btn btn-primary">Login</button>
    </form>
    <div class="mt-3">
        <span>Don't have an account?</span>
        <a class="btn btn-link" asp-action="Register">Register</a>
    </div>
    @if (ViewBag.Message != null)
    {
        <div class="alert alert-info mt-3">@ViewBag.Message</div>
    }
</div>
