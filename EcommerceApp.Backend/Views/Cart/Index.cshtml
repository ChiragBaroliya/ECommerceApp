@model IEnumerable<EcommerceApp.Backend.Models.CartItem>
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container mt-5">
    <h2 class="mb-4">Your Shopping Cart</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Your cart is empty. <a asp-controller="Home" asp-action="Index">Go shopping!</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Total</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="fw-bold text-primary">@item.ProductName</span>
                            </td>
                            <td>@item.UnitPrice.ToString("C")</td>
                            <td>
                                <form asp-action="Update" method="post" class="d-inline-flex">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm me-2" style="width: 70px;" />
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">Update</button>
                                </form>
                            </td>
                            <td>@item.TotalPrice.ToString("C")</td>
                            <td>
                                <form asp-action="Remove" method="post">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-active fw-bold">
                        <td colspan="3" class="text-end">Total Amount:</td>
                        <td>@Model.Sum(i => i.TotalPrice).ToString("C")</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="d-flex justify-content-between mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Continue Shopping</a>
            <button class="btn btn-success btn-lg">Checkout</button>
        </div>
    }
</div>

<style>
    .table th {
        border-top: none;
    }
    .btn-sm {
        padding: 0.25rem 0.5rem;
    }
</style>
