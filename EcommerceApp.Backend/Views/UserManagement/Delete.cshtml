@model EcommerceApp.Backend.Models.User
@{
    ViewData["Title"] = "Delete User";
}
<h2>Delete User</h2>
<div class="alert alert-warning">Are you sure you want to delete this user?</div>
<dl class="row">
    <dt class="col-sm-2">Username</dt>
    <dd class="col-sm-10">@Model.Username</dd>
    <dt class="col-sm-2">Full Name</dt>
    <dd class="col-sm-10">@Model.FullName</dd>
    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.Email</dd>
    <dt class="col-sm-2">Role</dt>
    <dd class="col-sm-10">@Model.Role</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Username" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
