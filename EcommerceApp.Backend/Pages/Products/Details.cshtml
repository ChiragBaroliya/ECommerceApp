@page "{id:int}"
@model EcommerceApp.Backend.Pages.Products.DetailsModel
@{
    ViewData["Title"] = "Product Details";
}
<h1>Product Details</h1>
<dl class="row">
    <dt class="col-sm-2">Gallery</dt>
    <dd class="col-sm-10">
        @if (!string.IsNullOrEmpty(Model.Product.ImagePath) || Model.Product.GalleryImages.Any())
        {
            var allImages = new List<string>();
            if (!string.IsNullOrEmpty(Model.Product.ImagePath)) allImages.Add(Model.Product.ImagePath);
            allImages.AddRange(Model.Product.GalleryImages);

            <div id="productGallery" class="carousel slide" data-bs-ride="carousel" style="max-width: 500px;">
                <div class="carousel-inner">
                    @for (int i = 0; i < allImages.Count; i++)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <img src="~/@allImages[i]" class="d-block w-100 rounded" alt="Product Image @i" style="height: 300px; object-fit: contain; background: #f8f9fa;">
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#productGallery" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#productGallery" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
                <div class="mt-2 d-flex flex-wrap">
                    @for (int i = 0; i < allImages.Count; i++)
                    {
                        <img src="~/@allImages[i]" data-bs-target="#productGallery" data-bs-slide-to="@i" class="img-thumbnail me-1" style="width: 60px; height: 60px; cursor: pointer; object-fit: cover;">
                    }
                </div>
            </div>
        }
        else
        {
            <span class="text-muted">No images available</span>
        }
    </dd>
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Html.Encode(Model.Product.Name)</dd>
    <dt class="col-sm-2">Category</dt>
    <dd class="col-sm-10">
        @{ var cat = EcommerceApp.Backend.Mock.MockCategoryStore.Categories.FirstOrDefault(c => c.Id == Model.Product.CategoryId); }
        @Html.Encode(cat?.Name ?? "")
    </dd>
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Html.Encode(Model.Product.Description)</dd>
    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Product.Price.ToString("C")</dd>
    <dt class="col-sm-2">Stock</dt>
    <dd class="col-sm-10">@Model.Product.Stock</dd>
</dl>
<a asp-page="Index" class="btn btn-secondary">Back to List</a>
@if (User.IsInRole("Admin") || User.IsInRole("Vendor"))
{
    <a asp-page="Edit" asp-route-id="@Model.Product.Id" class="btn btn-primary">Edit</a>
    <a asp-page="Delete" asp-route-id="@Model.Product.Id" class="btn btn-danger">Delete</a>
}
