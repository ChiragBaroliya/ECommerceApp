@page "{id:int}"
@model EcommerceApp.Backend.Pages.Products.DetailsModel
@{
    ViewData["Title"] = "Product Details";
}
<h1>Product Details</h1>
<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Html.Encode(Model.Product.Name)</dd>
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Html.Encode(Model.Product.Description)</dd>
    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Product.Price.ToString("C")</dd>
    <dt class="col-sm-2">Stock</dt>
    <dd class="col-sm-10">@Model.Product.Stock</dd>
</dl>
<a asp-page="Index" class="btn btn-secondary">Back to List</a>
@if (User.IsInRole("Admin") || User.IsInRole("Vendor"))
{
    <a asp-page="Edit" asp-route-id="@Model.Product.Id" class="btn btn-primary">Edit</a>
    <a asp-page="Delete" asp-route-id="@Model.Product.Id" class="btn btn-danger">Delete</a>
}
