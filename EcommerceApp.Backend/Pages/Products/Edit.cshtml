@page "{id:int}"
@model EcommerceApp.Backend.Pages.Products.EditModel
@{
    ViewData["Title"] = "Edit Product";
}
<h1>Edit Product</h1>
<form method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Product.Id" />
    <div class="form-group">
        <label asp-for="Product.Name"></label>
        <input asp-for="Product.Name" class="form-control" />
        <span asp-validation-for="Product.Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Product.CategoryId">Category</label>
        <select asp-for="Product.CategoryId" asp-items="Model.CategoryOptions" class="form-control"></select>
        <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Product.Description"></label>
        <textarea asp-for="Product.Description" class="form-control"></textarea>
        <span asp-validation-for="Product.Description" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Product.Price"></label>
        <input asp-for="Product.Price" class="form-control" />
        <span asp-validation-for="Product.Price" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Product.Stock"></label>
        <input asp-for="Product.Stock" class="form-control" />
        <span asp-validation-for="Product.Stock" class="text-danger"></span>
    </div>
    <div class="form-group pb-3">
        <label for="ProductImages">Product Gallery</label>
        <input type="file" name="ProductImages" class="form-control" accept="image/*" multiple />
        <div class="d-flex flex-wrap mt-2">
            @if (!string.IsNullOrEmpty(Model.Product.ImagePath))
            {
                <div class="card m-1" style="width: 120px;">
                    <img src="~/@Model.Product.ImagePath" class="card-img-top" alt="Primary Image" style="height: 100px; object-fit: cover;">
                    <div class="card-body p-1 text-center">
                        <span class="badge bg-primary mb-1">Primary</span>
                        <button type="submit" asp-page-handler="DeleteImage" asp-route-id="@Model.Product.Id" asp-route-imageUrl="@Model.Product.ImagePath" class="btn btn-danger btn-sm w-100">Delete</button>
                    </div>
                </div>
            }
            @foreach (var img in Model.Product.GalleryImages)
            {
                <div class="card m-1" style="width: 120px;">
                    <img src="~/@img" class="card-img-top" alt="Gallery Image" style="height: 100px; object-fit: cover;">
                    <div class="card-body p-1 text-center">
                        <button type="submit" asp-page-handler="DeleteImage" asp-route-id="@Model.Product.Id" asp-route-imageUrl="@img" class="btn btn-danger btn-sm w-100">Delete</button>
                    </div>
                </div>
            }
        </div>
    </div>
    <button type="submit" class="btn btn-success">Save</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
