@page "{id:int}"
@model EcommerceApp.Backend.Pages.Products.EditModel
@{
    ViewData["Title"] = "Edit Product";
}
<h1>Edit Product</h1>
<form method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Product.Id" />
    <div class="form-group">
        <label asp-for="Product.Name"></label>
        <input asp-for="Product.Name" class="form-control" />
        <span asp-validation-for="Product.Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Product.CategoryId">Category</label>
        <select asp-for="Product.CategoryId" asp-items="Model.CategoryOptions" class="form-control"></select>
        <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Product.Description"></label>
        <textarea asp-for="Product.Description" class="form-control"></textarea>
        <span asp-validation-for="Product.Description" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Product.Price"></label>
        <input asp-for="Product.Price" class="form-control" />
        <span asp-validation-for="Product.Price" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Product.Stock"></label>
        <input asp-for="Product.Stock" class="form-control" />
        <span asp-validation-for="Product.Stock" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="ProductImage">Product Image</label>
        <input type="file" name="ProductImage" class="form-control" accept="image/*" />
        @if (!string.IsNullOrEmpty(Model.Product.ImagePath))
        {
            <div class="mt-2">
                <img src="~/@Model.Product.ImagePath" alt="Product Image" style="max-width:120px;max-height:120px;" />
            </div>
        }
    </div>
    <button type="submit" class="btn btn-success">Save</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
