@page "{id:int}"
@model EcommerceApp.Backend.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Product";
}
<h1>Delete Product</h1>
<h3>Are you sure you want to delete this product?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Html.Encode(Model.Product.Name)</dd>
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Html.Encode(Model.Product.Description)</dd>
        <dt class="col-sm-2">Price</dt>
        <dd class="col-sm-10">@Model.Product.Price.ToString("C")</dd>
        <dt class="col-sm-2">Stock</dt>
        <dd class="col-sm-10">@Model.Product.Stock</dd>
    </dl>
    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Product.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
