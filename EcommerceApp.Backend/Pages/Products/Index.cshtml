@page
@model EcommerceApp.Backend.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<h1>Products</h1>
@if (User.IsInRole("Admin") || User.IsInRole("Vendor"))
{
    <a asp-page="Create" class="btn btn-primary mb-2">Create New Product</a>
}
<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover table-bordered align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Description</th>
                <th>Price</th>
                <th>Stock</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var product in Model.Products)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(product.ImagePath))
                    {
                        <img src="~/@product.ImagePath" alt="Product Image" style="max-width:60px;max-height:60px;" />
                    }
                </td>
                <td>@Html.Encode(product.Name)</td>
                <td>
                    @{ var cat = EcommerceApp.Backend.Mock.MockCategoryStore.Categories.FirstOrDefault(c => c.Id == product.CategoryId); }
                    @Html.Encode(cat?.Name ?? "")
                </td>
                <td>@Html.Encode(product.Description)</td>
                <td class="fw-bold text-success">@product.Price.ToString("C")</td>
                <td>
                    <span class="badge @(product.Stock > 10 ? "bg-success" : "bg-warning")">
                        @product.Stock
                    </span>
                </td>
                <td class="text-center">
                    <div class="btn-group btn-group-sm" role="group">
                        <a asp-page="Details" asp-route-id="@product.Id" class="btn btn-outline-info">Details</a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Vendor"))
                        {
                            <a asp-page="Edit" asp-route-id="@product.Id" class="btn btn-outline-primary">Edit</a>
                            <a asp-page="Delete" asp-route-id="@product.Id" class="btn btn-outline-danger">Delete</a>
                        }
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.min.js"></script>