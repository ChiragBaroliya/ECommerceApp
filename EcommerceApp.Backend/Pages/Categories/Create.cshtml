@page
@model EcommerceApp.Backend.Pages.Categories.CreateModel
@{
    ViewData["Title"] = "Create Category";
}
<h1>Create Category</h1>
<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Category.Name"></label>
        <input asp-for="Category.Name" class="form-control" />
        <span asp-validation-for="Category.Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Category.Description"></label>
        <textarea asp-for="Category.Description" class="form-control"></textarea>
        <span asp-validation-for="Category.Description" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-success">Create</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
