@page "{id:int}"
@model EcommerceApp.Backend.Pages.Categories.DetailsModel
@{
    ViewData["Title"] = "Category Details";
}
<h1>Category Details</h1>
<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Html.Encode(Model.Category.Name)</dd>
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Html.Encode(Model.Category.Description)</dd>
</dl>
<a asp-page="Index" class="btn btn-secondary">Back to List</a>
<a asp-page="Edit" asp-route-id="@Model.Category.Id" class="btn btn-primary">Edit</a>
<a asp-page="Delete" asp-route-id="@Model.Category.Id" class="btn btn-danger">Delete</a>
