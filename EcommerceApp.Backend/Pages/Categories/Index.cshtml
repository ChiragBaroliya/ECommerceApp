@page
@model EcommerceApp.Backend.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
}
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<h1>Categories</h1>
<a asp-page="Create" class="btn btn-primary mb-2">Create New Category</a>
<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover table-bordered align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var category in Model.Categories)
        {
            <tr>
                <td>@Html.Encode(category.Name)</td>
                <td>@Html.Encode(category.Description)</td>
                <td class="text-center">
                    <a asp-page="Details" asp-route-id="@category.Id" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-page="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-page="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.min.js"></script>
