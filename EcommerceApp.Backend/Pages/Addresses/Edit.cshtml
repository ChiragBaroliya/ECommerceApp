@page "{id:int}"
@model EcommerceApp.Backend.Pages.Addresses.EditModel
@{
    ViewData["Title"] = "Edit Address";
}

<h1>Edit Address</h1>

<form method="post">
    <input type="hidden" asp-for="Address.Id" />
    <div class="form-group">
        <label asp-for="Address.UserName"></label>
        <input asp-for="Address.UserName" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Address.Street"></label>
        <input asp-for="Address.Street" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Address.City"></label>
        <input asp-for="Address.City" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Address.State"></label>
        <input asp-for="Address.State" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Address.Zip"></label>
        <input asp-for="Address.Zip" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Address.Country"></label>
        <input asp-for="Address.Country" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
