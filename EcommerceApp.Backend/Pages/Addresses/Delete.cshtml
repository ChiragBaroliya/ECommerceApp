@page "{id:int}"
@model EcommerceApp.Backend.Pages.Addresses.DeleteModel
@{
    ViewData["Title"] = "Delete Address";
}

<h1>Delete Address</h1>

<h3>Are you sure you want to delete this address?</h3>
<div>
    <dl class="row">
        <dt class = "col-sm-2">User Name</dt>
        <dd class = "col-sm-10">@Model.Address.UserName</dd>
        <dt class = "col-sm-2">Street</dt>
        <dd class = "col-sm-10">@Model.Address.Street</dd>
        <dt class = "col-sm-2">City</dt>
        <dd class = "col-sm-10">@Model.Address.City</dd>
        <dt class = "col-sm-2">State</dt>
        <dd class = "col-sm-10">@Model.Address.State</dd>
        <dt class = "col-sm-2">Zip</dt>
        <dd class = "col-sm-10">@Model.Address.Zip</dd>
        <dt class = "col-sm-2">Country</dt>
        <dd class = "col-sm-10">@Model.Address.Country</dd>
    </dl>
    <form method="post">
        <input type="hidden" asp-for="Address.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
