@page
@model EcommerceApp.Backend.Pages.Addresses.IndexModel
@{
    ViewData["Title"] = "Addresses";
}
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<h1>Addresses</h1>
<p>
    <a asp-page="Create">Create New Address</a>
</p>
<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover table-bordered align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Id</th>
                <th>User Name</th>
                <th>Street</th>
                <th>City</th>
                <th>State</th>
                <th>Zip</th>
                <th>Country</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var address in Model.Addresses)
        {
            <tr>
                <td>@address.Id</td>
                <td>@address.UserName</td>
                <td>@address.Street</td>
                <td>@address.City</td>
                <td>@address.State</td>
                <td>@address.Zip</td>
                <td>@address.Country</td>
                <td class="text-center">
                    <div class="btn-group btn-group-sm" role="group">
                        <a asp-page="Edit" asp-route-id="@address.Id" class="btn btn-outline-primary">Edit</a>
                        <a asp-page="Delete" asp-route-id="@address.Id" class="btn btn-outline-danger">Delete</a>
                       
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.min.js"></script>

